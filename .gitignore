# ============================================
# EnvVarSwitcher .gitignore
# ============================================

# User profiles (may contain sensitive data like API keys)
profiles/*.json

# Keep example profiles
!profiles/dev.json
!profiles/prod.json

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Plan file (optional - remove if you want to track it)
PLAN.md
